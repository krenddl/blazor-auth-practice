@page "/privatechat/{userId:int}"
@implements IAsyncDisposable

@using BlazorPractice1.ApiRequests
@using BlazorPractice1.ApiRequests.Model
@using BlazorPractice1.ApiRequests.Services
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Json
@using System.Text.Json

<PageTitle>Личный чат</PageTitle>

<div class="chat-page private-chat-page">
    <div class="movies-topbar private-chat-head">
        <div>
            <a href="/messages" class="private-chat-back">← К диалогам</a>
            <h2 class="page-title">@PartnerLabel</h2>
            <p class="page-subtitle">Личные сообщения</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(hubError))
    {
        <div class="alert alert-error mb-20">@hubError</div>
    }

    <div class="card chat-card">
        <div class="chat-box">
            @if (messages.Count == 0)
            {
                <div class="chat-empty">Напишите первое сообщение</div>
            }
            else
            {
                @foreach (var m in messages)
                {
                    var isMine = AuthService.CurrentUser != null && m.senderId == AuthService.CurrentUser.id_User;

                    <div class="chat-message @(isMine ? "mine" : "other")">
                        <div class="chat-message-top">
                            <span class="chat-user">@(isMine ? "Вы" : PartnerLabel)</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(m.text))
                        {
                            <div>@m.text</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(m.imageUrl))
                        {
                            <img class="chat-image" src="@($"http://localhost:5126{m.imageUrl}")" alt="" />
                        }

                        @if (m.isEdited)
                        {
                            <div class="chat-edited">(изменено)</div>
                        }

                        @if (isMine)
                        {
                            <div class="chat-actions">
                                <button type="button" class="btn btn-outline btn-sm" @onclick="() => StartEdit(m)">Редактировать</button>
                                <button type="button" class="btn btn-danger btn-sm" @onclick="() => DeleteMessage(m.id_PrivateMessage)">Удалить</button>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <div class="card chat-card mt-20">
        <div class="chat-input-row">
            <input class="form-control" @bind="text" placeholder="Сообщение…" />
            <InputFile OnChange="OnFileChange" />
            <button type="button" class="btn btn-primary" @onclick="SendMessage" disabled="@(AuthService.CurrentUser == null)">Отправить</button>
        </div>

        @if (editingMessage != null)
        {
            <div class="chat-edit-panel">
                <div class="form-group">
                    <label class="form-label">Редактирование</label>
                    <input class="form-control" @bind="editText" />
                </div>
                <div class="form-group">
                    <InputFile OnChange="OnEditFileChange" />
                </div>
                <label class="form-label" style="display:flex; gap:8px; align-items:center;">
                    <input type="checkbox" @bind="removeImage" />
                    удалить фото
                </label>
                <div class="form-actions">
                    <button type="button" class="btn btn-success" @onclick="SaveEdit">Сохранить</button>
                    <button type="button" class="btn btn-outline" @onclick="CancelEdit">Отмена</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new() { PropertyNameCaseInsensitive = true };

    [Parameter] public int userId { get; set; }

    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private ApiRequest ApiRequest { get; set; } = default!;

    private HubConnection? hub;

    private List<PrivateMessageModel> messages = new();
    private string text = string.Empty;
    private IBrowserFile? file;
    private PrivateMessageModel? editingMessage;
    private string editText = string.Empty;
    private IBrowserFile? editFile;
    private bool removeImage;
    private string? hubError;
    private string PartnerLabel { get; set; } = "Собеседник";

    protected override async Task OnParametersSetAsync()
    {
        hubError = null;
        await AuthService.LoadSessionAsync();

        if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null || string.IsNullOrWhiteSpace(AuthService.Token))
        {
            Nav.NavigateTo("/login");
            return;
        }

        if (userId == AuthService.CurrentUser.id_User)
        {
            Nav.NavigateTo("/messages");
            return;
        }

        var directory = await ApiRequest.GetUsersForChatAsyncResponse(AuthService.Token);
        var entry = directory.users?.FirstOrDefault(u => u.id_User == userId);
        PartnerLabel = string.IsNullOrWhiteSpace(entry?.Name) ? $"Пользователь {userId}" : entry!.Name!;

        if (hub is { State: HubConnectionState.Connected })
            return;

        await DisposeHubAsync();

        Http.DefaultRequestHeaders.Remove("Authorization");
        Http.DefaultRequestHeaders.Add("Authorization", AuthService.Token);

        hub = new HubConnectionBuilder()
            .WithUrl("http://localhost:5126/chathub")
            .WithAutomaticReconnect()
            .Build();

        hub.On<PrivateMessageModel>("ReceivePrivateMessage", msg =>
            InvokeAsync(() =>
            {
                if (IsParticipant(msg))
                {
                    messages.Add(msg);
                    StateHasChanged();
                }
            }));

        hub.On<PrivateMessageModel>("UpdatePrivateMessage", msg =>
            InvokeAsync(() =>
            {
                var m = messages.FirstOrDefault(x => x.id_PrivateMessage == msg.id_PrivateMessage);
                if (m != null)
                {
                    m.text = msg.text;
                    m.imageUrl = msg.imageUrl;
                    m.isEdited = msg.isEdited;
                    StateHasChanged();
                }
            }));

        hub.On<int>("DeletePrivateMessage", id =>
            InvokeAsync(() =>
            {
                var m = messages.FirstOrDefault(x => x.id_PrivateMessage == id);
                if (m != null)
                {
                    messages.Remove(m);
                    StateHasChanged();
                }
            }));

        try
        {
            await hub.StartAsync();
            var me = AuthService.CurrentUser.id_User;
            await hub.InvokeAsync("JoinPrivateChat", me, userId);
            await LoadMessages();
        }
        catch (Exception ex)
        {
            hubError = $"Не удалось подключиться: {ex.Message}";
        }
    }

    private bool IsParticipant(PrivateMessageModel msg)
    {
        if (AuthService.CurrentUser == null) return false;
        var me = AuthService.CurrentUser.id_User;
        return (msg.senderId == me && msg.receiverId == userId) ||
               (msg.senderId == userId && msg.receiverId == me);
    }

    private async Task LoadMessages()
    {
        messages = new List<PrivateMessageModel>();
        if (AuthService.CurrentUser == null) return;

        try
        {
            var me = AuthService.CurrentUser.id_User;
            var response = await Http.GetAsync($"GetPrivateMessages?userId1={me}&userId2={userId}");
            if (!response.IsSuccessStatusCode)
                return;

            var res = await response.Content.ReadFromJsonAsync<PrivateMessageResponse>(JsonOptions);
            if (res?.privateMessageModels != null)
                messages = res.privateMessageModels;
        }
        catch
        {
        }
    }

    private async Task SendMessage()
    {
        if (AuthService.CurrentUser == null)
            return;

        var content = new MultipartFormDataContent();
        content.Add(new StringContent(AuthService.CurrentUser.id_User.ToString()), "senderId");
        content.Add(new StringContent(userId.ToString()), "receiverId");

        if (!string.IsNullOrWhiteSpace(text))
            content.Add(new StringContent(text), "text");

        if (file != null)
        {
            var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", file.Name);
        }

        await Http.PostAsync("SendPrivateMessage", content);

        text = string.Empty;
        file = null;
    }

    private async Task DeleteMessage(int id)
    {
        await Http.DeleteAsync($"DeletePrivateMessage?privateMessageId={id}");
    }

    private void StartEdit(PrivateMessageModel m)
    {
        editingMessage = m;
        editText = m.text ?? string.Empty;
    }

    private async Task SaveEdit()
    {
        if (editingMessage == null)
            return;

        var content = new MultipartFormDataContent();
        content.Add(new StringContent(editingMessage.id_PrivateMessage.ToString()), "id_PrivateMessage");

        if (editText != null)
            content.Add(new StringContent(editText), "text");

        content.Add(new StringContent(removeImage.ToString()), "removeCurrentImage");

        if (editFile != null)
        {
            var stream = editFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            content.Add(new StreamContent(stream), "newFile", editFile.Name);
        }

        await Http.PutAsync("UpdatePrivateMessage", content);

        editingMessage = null;
        removeImage = false;
        editFile = null;
    }

    private void CancelEdit()
    {
        editingMessage = null;
        removeImage = false;
        editFile = null;
    }

    private void OnFileChange(InputFileChangeEventArgs e)
    {
        file = e.File;
    }

    private void OnEditFileChange(InputFileChangeEventArgs e)
    {
        editFile = e.File;
    }

    private async Task DisposeHubAsync()
    {
        if (hub is null)
            return;

        try
        {
            if (AuthService.CurrentUser != null)
                await hub.InvokeAsync("LeavePrivateChat", AuthService.CurrentUser.id_User, userId);
        }
        catch
        {
            
        }

        await hub.DisposeAsync();
        hub = null;
    }

    public async ValueTask DisposeAsync()
    {
        await DisposeHubAsync();
    }

}
